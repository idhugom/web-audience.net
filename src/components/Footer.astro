---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { SITE } from '../data/site';
import { CATEGORIES } from '../data/categories';
const year = new Date().getFullYear();
const cols = CATEGORIES.slice(0, 8);
---
<footer class="site-footer">
  <div class="footer-glow" aria-hidden="true"></div>
  <div class="container footer-inner">
    <div class="footer-brand">
      <Logo />
      <p class="footer-tag">{SITE.description}</p>
      <div class="footer-links-row">
        <a href="/rss.xml" class="mini-link"><Icon name="rss" size={15} /> Flux RSS</a>
        <a href={`mailto:${SITE.email}`} class="mini-link"><Icon name="mail" size={15} /> Contact</a>
      </div>
    </div>
    <div class="footer-col">
      <h3 class="footer-title">Thématiques</h3>
      <ul>
        {cols.map((c) => <li><a href={`/thematiques/${c.slug}`}>{c.name}</a></li>)}
      </ul>
    </div>
    <div class="footer-col">
      <h3 class="footer-title">Explorer</h3>
      <ul>
        <li><a href="/blog">Tous les articles</a></li>
        <li><a href="/thematiques">Toutes les thématiques</a></li>
        <li><a href="/recherche">Recherche</a></li>
        <li><a href="/a-propos">À propos</a></li>
      </ul>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>© {year} {SITE.name}.net — Le web décrypté.</p>
    <p class="footer-made">Conçu pour comprendre et agir en ligne.</p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    margin-top: 80px;
    background: var(--slate-50);
    border-top: 1px solid var(--border);
    overflow: hidden;
  }
  .footer-glow {
    position: absolute;
    inset: auto 0 auto 0;
    top: -40%;
    height: 300px;
    background: radial-gradient(60% 60% at 20% 0%, rgba(37,99,235,0.10), transparent 70%),
                radial-gradient(50% 50% at 90% 10%, rgba(6,182,212,0.08), transparent 70%);
    pointer-events: none;
  }
  .footer-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 40px;
    padding-block: 56px 32px;
  }
  .footer-tag { color: var(--slate-500); font-size: 0.95rem; max-width: 42ch; margin: 16px 0 18px; }
  .footer-links-row { display: flex; gap: 18px; flex-wrap: wrap; }
  .mini-link { display: inline-flex; align-items: center; gap: 7px; font-size: 0.85rem; color: var(--slate-600); font-weight: 500; }
  .mini-link:hover { color: var(--blue-700); }
  .footer-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--slate-500);
    margin-bottom: 14px;
  }
  .footer-col ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .footer-col a { color: var(--slate-600); font-size: 0.92rem; }
  .footer-col a:hover { color: var(--blue-700); }
  .footer-bottom {
    position: relative;
    display: flex;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    padding-block: 22px 30px;
    border-top: 1px solid var(--border);
    color: var(--slate-500);
    font-size: 0.85rem;
  }
  .footer-made { font-family: var(--font-mono); font-size: 0.78rem; }
  @media (max-width: 720px) {
    .footer-inner { grid-template-columns: 1fr 1fr; gap: 30px; }
    .footer-brand { grid-column: 1 / -1; }
  }
</style>
