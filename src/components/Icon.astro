  heart: '<path d="M12 20s-7-4.5-9.2-8.4C1.2 8.7 2.6 5.5 5.7 5.5c1.9 0 3.1 1.1 3.8 2.2h.9c.7-1.1 1.9-2.2 3.8-2.2 3.1 0 4.5 3.2 2.9 6.1C19 15.5 12 20 12 20Z"/>',
  compass: '<circle cx="12" cy="12" r="9"/><path d="m15.5 8.5-2 5-5 2 2-5 5-2Z"/>',
  car: '<path d="M5 12l1.5-4.5A2 2 0 0 1 8.4 6h7.2a2 2 0 0 1 1.9 1.5L19 12"/><path d="M4 12h16v5H4v-5Z"/><circle cx="7.5" cy="17" r="1.5"/><circle cx="16.5" cy="17" r="1.5"/>',
