---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
---
<BaseLayout
  title="Recherche"
  description="Recherchez parmi tous les guides et articles de web-audience."
  noindex={true}
>
  <section class="search-hero grid-bg">
    <div class="container container-narrow">
      <p class="eyebrow">Recherche</p>
      <h1 class="search-title">Que cherchez-vous ?</h1>
      <p class="search-sub">Tapez un mot-clé pour explorer l'ensemble de nos articles.</p>
      <div id="search" class="search-box"></div>
      <noscript><p class="ns">La recherche nécessite JavaScript. <a href="/blog/">Parcourir tous les articles →</a></p></noscript>
    </div>
  </section>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" slot="head" />
  <script>
    // @ts-nocheck
    function boot() {
      if (typeof PagefindUI === 'undefined') { setTimeout(boot, 120); return; }
      const ui = new PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: true,
        pageSize: 8,
        translations: {
          placeholder: 'Rechercher un article, un sujet…',
          clear_search: 'Effacer',
          load_more: 'Voir plus de résultats',
          search_label: 'Rechercher',
          zero_results: 'Aucun résultat pour « [SEARCH_TERM] »',
          many_results: '[COUNT] résultats pour « [SEARCH_TERM] »',
          one_result: '[COUNT] résultat pour « [SEARCH_TERM] »',
          searching: 'Recherche de « [SEARCH_TERM] »…',
        },
      });
      const params = new URLSearchParams(window.location.search);
      const q = params.get('q');
      if (q) {
        const input = document.querySelector('#search input');
        if (input) { input.value = q; input.dispatchEvent(new Event('input', { bubbles: true })); }
      }
    }
    const s = document.createElement('script');
    s.src = '/pagefind/pagefind-ui.js';
    s.onload = boot;
    document.head.appendChild(s);
  </script>
</BaseLayout>

<style>
  .search-hero { padding-block: 54px 90px; min-height: 70vh; }
  .search-title { font-size: clamp(2rem, 5vw, 3rem); margin: 14px 0 8px; }
  .search-sub { color: var(--slate-600); font-size: 1.1rem; margin: 0 0 30px; }
  .search-box { margin-top: 10px; }
  .ns { color: var(--slate-600); }
  :global(.pagefind-ui__search-input) { font-family: var(--font-body) !important; border-radius: var(--r-md) !important; }
  :global(.pagefind-ui__result) { border-radius: var(--r-md); }
</style>
